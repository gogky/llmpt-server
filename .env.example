# MongoDB 配置
MONGODB_URI=mongodb://admin:admin123@localhost:27017
MONGODB_DATABASE=hf_p2p_v1
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin123
# MongoDB 连接池（可选，不设置则使用默认值）
# MONGODB_MAX_POOL_SIZE=50
# MONGODB_MIN_POOL_SIZE=10
# MONGODB_MAX_CONN_IDLE_TIME=30s

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Redis 连接池（可选，不设置则使用默认值）
# REDIS_POOL_SIZE=50
# REDIS_MIN_IDLE_CONNS=10

# 服务器配置
SERVER_PORT=8080
TRACKER_PORT=8081
TRACKER_URL=http://localhost/announce
ENVIRONMENT=development

# Tracker 调度与频率限制（可选，不设置则使用默认值）
# ANNOUNCE_INTERVAL=1800s
# （注：后台死亡节点清理任务的判定线自动绑定为 2 * ANNOUNCE_INTERVAL，无需额外配置）
# ANNOUNCE_MIN_INTERVAL=900s
# RATE_LIMIT_WINDOW=15m
# RATE_LIMIT_BURST=30

# 安全与权限配置
# 用于后台管理接口的静态鉴权 Token
ADMIN_TOKEN=your_secure_admin_token_here
# 用于让服务器在后端爬取 Gated/Private Repo 文件大小做对比的 HF Token（不填则门禁库设为 pending）
# HF_TOKEN=hf_xxxxxx
# HuggingFace API 镜像地址，默认为 https://huggingface.co
# HF_ENDPOINT=https://hf-mirror.com
